{
  "name": "cinemaguide",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://rayrable01.github.io/CinemaGuide/",
  "scripts": {
    "dev": "concurrently \"npm run dev:stub\" \"vite\"",
    "dev:stub": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "predeploy": "npm run build",
    "deploy": "gh-pages -r https://github.com/rayrable01/CinemaGuide.git -b gh-pages -d dist",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.13.2",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-player": "^2.16.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "gh-pages": "^6.3.0",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.9"
  }
}
